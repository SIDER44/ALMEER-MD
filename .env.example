# ✞『✦𝑨𝑳𝑴𝑬𝑬𝑹 ✠ 𝑴𝑫✦』✞ — Environment Variables

# ── Bot Identity ──────────────────────────────────────
BOT_NAME=✞『✦𝑨𝑳𝑴𝑬𝑬𝑹 ✠ 𝑴𝑫✦』✞
BOT_VERSION=v5.0.0
DEVELOPER=SIDER44

# ── Owner ──────────────────────────────────────────────
# Your WhatsApp number (no + sign, include country code)
OWNER_NUMBER=254712345678
OWNER_NAME=Owner

# ── Commands ───────────────────────────────────────────
PREFIX=.
# public = anyone can use | private = owner only
MODE=public

# ── Session ────────────────────────────────────────────
# Base64-encoded creds.json for cold starts (Pterodactyl / Railway)
# Leave blank to use pairing site on first boot
SESSION_ID=

# ── Server ─────────────────────────────────────────────
PORT=3000
API_SECRET=almeer-md-secret-change-this
DASHBOARD_PASS=almeermd2024

# ── Database ───────────────────────────────────────────
DB_PATH=./database/db.json

# ── External APIs ──────────────────────────────────────
# Groq API key for AI commands (free at console.groq.com)
GROQ_API_KEY=

# ── Features ───────────────────────────────────────────
# Auto-view and react to status updates (true/false)
AUTOSTATUS=true
# Reject incoming calls automatically (true/false)
ANTI_CALL=false
# Mark messages as read automatically (true/false)
AUTO_READ=true
# Show typing indicator when processing commands (true/false)
AUTO_TYPING=true

# ── Cooldowns ──────────────────────────────────────────
# Milliseconds between commands per user
CMD_COOLDOWN=3000
